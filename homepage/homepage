<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Web Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* ── DESKTOP BACKGROUND ── */
    body {
      font-family: 'Press Start 2P', monospace;
      background-color: #9b9bcd;           /* classic Win95 teal-ish, but purple */
      background-image:
        radial-gradient(ellipse at 30% 40%, rgba(255,150,220,0.35) 0%, transparent 55%),
        radial-gradient(ellipse at 75% 70%, rgba(180,120,255,0.3) 0%, transparent 55%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── DESKTOP AREA ── */
    .desktop {
      flex: 1;
      padding: 24px 20px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    /* ── DESKTOP ICON ── */
    .icon {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      width: 90px;
      cursor: pointer;
      text-decoration: none;
    }

    .icon:hover .icon-img {
      outline: 2px dotted white;
      background-color: rgba(0, 0, 120, 0.4);
      filter: brightness(1.15);
    }

    .icon:hover .icon-label {
      background-color: #000080;
      color: white;
    }

    /* The "folder/program" graphic */
    .icon-img {
      width: 72px;
      height: 72px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      image-rendering: pixelated;
      padding: 4px;
    }

    /* CSS pixel monitor icon */
    .monitor {
      width: 60px;
      height: 52px;
      background: #c8b8e8;
      border-top: 3px solid #fff;
      border-left: 3px solid #fff;
      border-right: 3px solid #555;
      border-bottom: 3px solid #555;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
    }

    .monitor-screen {
      width: 46px;
      height: 32px;
      border-top: 2px solid #555;
      border-left: 2px solid #555;
      border-right: 2px solid #fff;
      border-bottom: 2px solid #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: bold;
      color: white;
      letter-spacing: 0;
    }

    .monitor-stand {
      width: 14px;
      height: 5px;
      background: #a090c0;
      border-top: 1px solid #555;
    }

    .monitor-base {
      width: 24px;
      height: 4px;
      background: #b0a0d0;
      border-top: 1px solid #555;
      border-left: 1px solid #fff;
      border-right: 1px solid #555;
    }

    /* each era gets its own screen colour */
    .era-1990 .monitor-screen { background: #2a2a6a; }
    .era-2000 .monitor-screen { background: #6a1a5a; }
    .era-2010 .monitor-screen { background: #1a4a6a; }

    .icon-label {
      font-family: 'Press Start 2P', monospace;
      font-size: 7px;
      color: white;
      text-align: center;
      text-shadow: 1px 1px 0 #000;
      line-height: 1.4;
      padding: 2px 4px;
    }

    /* ── TASKBAR ── */
    .taskbar {
      height: 38px;
      background: #c0b8d8;
      border-top: 2px solid #fff;
      display: flex;
      align-items: center;
      padding: 0 4px;
      gap: 6px;
      flex-shrink: 0;
    }

    /* WIN95-style raised/sunken button mixin */
    .win-raised {
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-right: 2px solid #555;
      border-bottom: 2px solid #555;
    }

    .win-sunken {
      border-top: 2px solid #555;
      border-left: 2px solid #555;
      border-right: 2px solid #fff;
      border-bottom: 2px solid #fff;
    }

    /* Start button */
    .start-btn {
      height: 28px;
      padding: 0 10px;
      background: #c0b8d8;
      font-family: 'Press Start 2P', monospace;
      font-size: 8px;
      color: #000;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-right: 2px solid #555;
      border-bottom: 2px solid #555;
      user-select: none;
    }

    .start-btn:active {
      border-top: 2px solid #555;
      border-left: 2px solid #555;
      border-right: 2px solid #fff;
      border-bottom: 2px solid #fff;
    }

    .start-logo {
      width: 16px;
      height: 16px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 1px;
    }

    .start-logo span:nth-child(1) { background: #ff4444; }
    .start-logo span:nth-child(2) { background: #44aa44; }
    .start-logo span:nth-child(3) { background: #4444ff; }
    .start-logo span:nth-child(4) { background: #ffaa00; }

    /* Taskbar divider */
    .tb-divider {
      width: 2px;
      height: 26px;
      border-left: 1px solid #888;
      border-right: 1px solid #fff;
    }

    /* Clock */
    .tb-clock {
      margin-left: auto;
      height: 28px;
      padding: 0 10px;
      font-family: 'Press Start 2P', monospace;
      font-size: 8px;
      display: flex;
      align-items: center;
      border-top: 2px solid #555;
      border-left: 2px solid #555;
      border-right: 2px solid #fff;
      border-bottom: 2px solid #fff;
    }

    /* ── WINDOW POPUP ── */
    .window-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.3);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }

    .window-overlay.open {
      display: flex;
    }

    .win-window {
      background: #c0b8d8;
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-right: 2px solid #333;
      border-bottom: 2px solid #333;
      width: min(380px, 90vw);
      font-family: 'Press Start 2P', monospace;
    }

    .win-titlebar {
      background: #000080;
      color: white;
      font-size: 9px;
      padding: 5px 8px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .win-titlebar-btns {
      display: flex;
      gap: 3px;
    }

    .win-btn {
      width: 16px;
      height: 14px;
      background: #c0b8d8;
      font-size: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #000;
      border-top: 1px solid #fff;
      border-left: 1px solid #fff;
      border-right: 1px solid #555;
      border-bottom: 1px solid #555;
      line-height: 1;
    }

    .win-btn:active {
      border-top: 1px solid #555;
      border-left: 1px solid #555;
      border-right: 1px solid #fff;
      border-bottom: 1px solid #fff;
    }

    .win-body {
      padding: 20px;
      text-align: center;
    }

    .win-body p {
      font-size: 8px;
      line-height: 2;
      margin-bottom: 16px;
      color: #000;
    }

    .win-open-btn {
      display: inline-block;
      background: #c0b8d8;
      font-family: 'Press Start 2P', monospace;
      font-size: 8px;
      padding: 8px 16px;
      cursor: pointer;
      color: #000;
      text-decoration: none;
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-right: 2px solid #555;
      border-bottom: 2px solid #555;
    }

    .win-open-btn:hover {
      background: #d0c8e8;
    }

    .win-open-btn:active {
      border-top: 2px solid #555;
      border-left: 2px solid #555;
      border-right: 2px solid #fff;
      border-bottom: 2px solid #fff;
    }

    /* ── MEDIA QUERIES ── */
    @media (max-width: 480px) {
      .desktop {
        flex-direction: row;
        flex-wrap: wrap;
        align-items: flex-start;
      }
      .icon { width: 80px; }
      .taskbar { height: 34px; }
      .start-btn { font-size: 7px; padding: 0 8px; }
    }

    @media (min-width: 900px) {
      .desktop { padding: 32px 32px; gap: 20px; }
    }
  </style>
</head>
<body>

  <!-- ── DESKTOP ── -->
  <div class="desktop">

    <!-- Icon: 1990 -->
    <div class="icon" onclick="openWin('win1990')">
      <div class="icon-img era-1990">
        <div class="monitor">
          <div class="monitor-screen">1990</div>
          <div class="monitor-stand"></div>
          <div class="monitor-base"></div>
        </div>
      </div>
      <div class="icon-label">1990s Web</div>
    </div>

    <!-- Icon: 2000 -->
    <div class="icon" onclick="openWin('win2000')">
      <div class="icon-img era-2000">
        <div class="monitor">
          <div class="monitor-screen">2000</div>
          <div class="monitor-stand"></div>
          <div class="monitor-base"></div>
        </div>
      </div>
      <div class="icon-label">2000s Web</div>
    </div>

    <!-- Icon: 2010 -->
    <div class="icon" onclick="openWin('win2010')">
      <div class="icon-img era-2010">
        <div class="monitor">
          <div class="monitor-screen">2010</div>
          <div class="monitor-stand"></div>
          <div class="monitor-base"></div>
        </div>
      </div>
      <div class="icon-label">2010s Web</div>
    </div>

  </div>

  <!-- ── TASKBAR ── -->
  <div class="taskbar">
    <div class="start-btn" onclick="alert('Start Menu — coming soon!')">
      <div class="start-logo">
        <span></span><span></span><span></span><span></span>
      </div>
      Start
    </div>
    <div class="tb-divider"></div>
    <div class="tb-clock" id="clock">00:00</div>
  </div>

  <!-- ── POPUP: 1990 ── -->
  <div class="window-overlay" id="win1990">
    <div class="win-window">
      <div class="win-titlebar">
        <span>📁 1990s Web</span>
        <div class="win-titlebar-btns">
          <div class="win-btn" onclick="closeWin('win1990')">_</div>
          <div class="win-btn">□</div>
          <div class="win-btn" onclick="closeWin('win1990')">✕</div>
        </div>
      </div>
      <div class="win-body">
        <p>Welcome to the<br>1990s Web Era.<br><br>Geocities. Blink tags.<br>Under construction GIFs.</p>
        <a class="win-open-btn" href="1990.html">Open →</a>
      </div>
    </div>
  </div>

  <!-- ── POPUP: 2000 ── -->
  <div class="window-overlay" id="win2000">
    <div class="win-window">
      <div class="win-titlebar">
        <span>📁 2000s Web</span>
        <div class="win-titlebar-btns">
          <div class="win-btn" onclick="closeWin('win2000')">_</div>
          <div class="win-btn">□</div>
          <div class="win-btn" onclick="closeWin('win2000')">✕</div>
        </div>
      </div>
      <div class="win-body">
        <p>Welcome to the<br>2000s Web Era.<br><br>Flash. MySpace.<br>Web 2.0 gradients.</p>
        <a class="win-open-btn" href="2000.html">Open →</a>
      </div>
    </div>
  </div>

  <!-- ── POPUP: 2010 ── -->
  <div class="window-overlay" id="win2010">
    <div class="win-window">
      <div class="win-titlebar">
        <span>📁 2010s Web</span>
        <div class="win-titlebar-btns">
          <div class="win-btn" onclick="closeWin('win2010')">_</div>
          <div class="win-btn">□</div>
          <div class="win-btn" onclick="closeWin('win2010')">✕</div>
        </div>
      </div>
      <div class="win-body">
        <p>Welcome to the<br>2010s Web Era.<br><br>Flat design. Bootstrap.<br>Mobile-first everything.</p>
        <a class="win-open-btn" href="2010.html">Open →</a>
      </div>
    </div>
  </div>

  <script>
    /* Clock */
    function updateClock() {
      const now = new Date();
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      document.getElementById('clock').textContent = h + ':' + m;
    }
    updateClock();
    setInterval(updateClock, 10000);

    /* Window open/close */
    function openWin(id) {
      document.getElementById(id).classList.add('open');
    }
    function closeWin(id) {
      document.getElementById(id).classList.remove('open');
    }

    /* Click outside window to close */
    document.querySelectorAll('.window-overlay').forEach(overlay => {
      overlay.addEventListener('click', function(e) {
        if (e.target === this) closeWin(this.id);
      });
    });
  </script>
</body>
</html>